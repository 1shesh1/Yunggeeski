# Included from this repo's .git/config — see scripts/Install-GitAliases.ps1
#
# Note: Git does not allow a safe alias named "commit" that runs `git commit`
# (builtin/alias recursion). Use `git cm` for "stage everything and commit".

[alias]
	cm = "!f() { sh \"$(git rev-parse --show-toplevel)/scripts/git-commit.sh\" \"$@\"; }; f"
	pr = "!f() { sh \"$(git rev-parse --show-toplevel)/scripts/git-pr.sh\" \"$@\"; }; f"
