# Site
NEXT_PUBLIC_SITE_URL=https://yunggeeski.com
# Or use NEXT_PUBLIC_BASE_URL for deploy URL (e.g. https://yoursite.netlify.app)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Set to "true" to run without real credentials (Stripe, Supabase, Resend).
# When false and keys are set, checkout/orders/emails use real APIs.
MOCK_MODE=false

# Stripe (required when MOCK_MODE=false)
# Publishable key (pk_test_... or pk_live_) — safe for client; from Dashboard → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Secret key (sk_test_... or sk_live_) — server only; from Dashboard → API keys. Do NOT use a price_ ID here.
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_...) — from Dashboard → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs (price_...) — tiers and add-ons from your Products/Prices in Stripe
STRIPE_PRICE_BASIC=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PREMIUM=
STRIPE_ADDON_RUSH=
STRIPE_ADDON_REVISION=
STRIPE_ADDON_CSV=
STRIPE_ADDON_RESEARCH=
STRIPE_ADDON_CAPTION=
STRIPE_ADDON_COLLAB=
# Course (Learn page) — Price IDs for tier1, tier2, tier3
STRIPE_COURSE_TIER1=
STRIPE_COURSE_TIER2=
STRIPE_COURSE_TIER3=

# Supabase (required when MOCK_MODE=false)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=order-assets

# Resend (required when MOCK_MODE=false)
RESEND_API_KEY=
EMAIL_FROM=orders@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# Admin (optional). Set a secret; no login link on site. Visit /admin and enter this as the password.
ADMIN_SECRET=

# Course magic-link + session cookies (HS256). Required in production — min 32 characters.
COURSE_ACCESS_JWT_SECRET=
